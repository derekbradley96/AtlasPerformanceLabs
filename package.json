{
  "name": "atlas-performance-labs-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0 <21.0.0"
  },
  "scripts": {
    "start": "vite",
    "test": "node --test src/lib/intelligence/__tests__/rules.test.js",
    "test:unit": "vitest run",
    "test:inbox": "vitest run src/lib/inbox",
    "dev": "vite",
    "dev:mobile": "vite --host",
    "build": "vite build",
    "build:debug": "VITE_BUILD_DEBUG=1 vite build",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p ./jsconfig.json",
    "preview": "vite preview",
    "assets": "node scripts/generate-capacitor-resources.mjs && npx capacitor-assets generate --assetPath resources --iconBackgroundColor '#0F172A' --iconBackgroundColorDark '#0F172A' --splashBackgroundColor '#0F172A' --splashBackgroundColorDark '#0F172A'",
    "cap:init": "npx cap init \"Atlas Performance Labs\" \"com.atlasperformancelabs.app\" --web-dir=dist",
    "cap:sync": "npm run build && npx cap sync",
    "cap:sync:all": "npm run build && npx cap sync",
    "android": "npm run cap:sync && npx cap open android",
    "ios": "node scripts/ensure-ios.mjs",
    "open:ios": "open ios/App/App.xcodeproj",
    "ios:live": "CAPACITOR_SERVER_URL=http://localhost:5174 npx cap sync ios && npx cap open ios",
    "android:live": "CAPACITOR_SERVER_URL=http://localhost:5174 npx cap sync android && npx cap open android",
    "db:push": "npx supabase db push --include-all",
    "db:push:dry": "npx supabase db push --include-all --dry-run",
    "db:check-migrations": "node scripts/check-migrations.mjs",
    "doctor": "node scripts/doctor.js",
    "doctor:legacy": "npm run lint && npm run typecheck && npm run analyze && npm run test:unit",
    "analyze": "madge --circular --extensions js,jsx,ts,tsx src",
    "cap:ios:live": "vite build --watch & npx cap sync ios",
    "cap:android:live": "vite build --watch & npx cap sync android",
    "reset-project": "rm -rf node_modules dist .vite && npm install",
    "expo": "echo \"This project uses Vite + Capacitor, not Expo. Use: npm run dev (web) or npm run ios (iOS simulator).\"",
    "security:audit": "npm audit --omit=dev",
    "security:audit:fix": "npm audit fix --omit=dev",
    "security:osv": "npx osv-scanner@latest --lockfile=package-lock.json",
    "security:full": "npm run security:audit && npm run security:osv"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.3",
    "@capacitor/browser": "^6.0.6",
    "@capacitor/clipboard": "^6.0.0",
    "@capacitor/core": "^6.2.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/keyboard": "^6.0.2",
    "@capacitor/local-notifications": "^6.0.2",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/push-notifications": "^6.0.2",
    "@capacitor/share": "^6.0.2",
    "@capacitor/splash-screen": "^6.0.4",
    "@emotion/is-prop-valid": "^0.8.8",
    "@hello-pangea/dnd": "^17.0.0",
    "@hookform/resolvers": "^4.1.2",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-aspect-ratio": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-context-menu": "^2.2.6",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@stripe/react-stripe-js": "^3.0.0",
    "@stripe/stripe-js": "^5.2.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-query": "^5.84.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.5.2",
    "framer-motion": "^11.16.4",
    "html2canvas": "^1.4.1",
    "input-otp": "^1.4.2",
    "jspdf": "^4.0.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.475.0",
    "moment": "^2.30.1",
    "next-themes": "^0.4.4",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^9.0.1",
    "react-quill": "^2.0.0",
    "react-resizable-panels": "^2.1.7",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.1",
    "stripe": "^17.4.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.171.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/ios": "^6.2.1",
    "@eslint/js": "^9.19.0",
    "@types/node": "^22.13.5",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.39.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^15.14.0",
    "jimp": "^0.22.12",
    "madge": "^8.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.1.0",
    "vite-plugin-circular-dependency": "^0.5.0",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "minimatch": "^9.0.7",
    "tar": "^7.0.0"
  }
}
