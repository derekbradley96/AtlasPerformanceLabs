# Atlas Performance Labs – env template
# Copy to .env or .env.local and fill in. Do NOT commit real values.

# Required for auth and data (build-time inlined by Vite)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Optional: use real Supabase instead of demo mode (default is demo if unset)
# VITE_APP_MODE=real

# Optional: dev-only analytics logging
# VITE_DEV_ANALYTICS_LOG=false

# Optional: build with debug symbols (no minification) for easier debugging
# VITE_BUILD_DEBUG=0

# Server / Edge Functions only (never in client bundle):
# SUPABASE_SERVICE_ROLE_KEY=...
# STRIPE_SECRET_KEY=...
# STRIPE_WEBHOOK_SECRET=...
# FCM_SERVER_KEY=...
